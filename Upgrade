# Node label shows pre-installed drivers
kubectl describe node scs05 | grep nvidia.com/gpu.deploy.driver
nvidia.com/gpu.deploy.driver=pre-installed

# ClusterPolicy expects GPU operator to manage drivers
kubectl get clusterpolicies.nvidia.com cluster-policy -o jsonpath='{.spec.driver.enabled}'
true

