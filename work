# Check driver daemonset now has pods
kubectl get daemonset -n hpecp-gpu-operator nvidia-driver-daemonset

# Verify node label changed to true
kubectl get nodes -l nvidia.com/gpu.present \
  -o jsonpath='{range .items[*]}{.metadata.name}{"\t"}{.metadata.labels.nvidia\.com/gpu\.deploy\.driver}{"\n"}{end}'

# Confirm driver version (access via driver pod since GPU operator manages drivers)
kubectl exec -n hpecp-gpu-operator <driver-pod-name> -- nvidia-smi --query-gpu=driver_version --format=csv,noheader
